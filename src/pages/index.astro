---
const navigation = [
  { name: "About", href: "#about" },
  { name: "Understanding IBD", href: "#ibd" },
  { name: "Resources", href: "#resources" },
  { name: "Get Involved", href: "#involved" },
  { name: "Contact", href: "#contact" }
];
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Digestive Harmony</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      font-family:Arial, Helvetica, sans-serif;
      background:#F7FAFC;
      color:#123;
      line-height:1.6;
    }

    header{
      background:white;
      padding:18px 10%;
      display:flex;
      justify-content:space-between;
      align-items:center;
      box-shadow:0 2px 12px rgba(0,0,0,.06);
      position:sticky;
      top:0;
      z-index:100;
    }

    .logo{
      font-size:1.5rem;
      font-weight:bold;
      color:#005B70;
    }

    nav a{
      margin-left:24px;
      text-decoration:none;
      color:#0F4C5C;
      font-weight:600;
    }

    .hero{
      min-height:88vh;
      display:flex;
      align-items:center;
      justify-content:center;
      text-align:center;
      padding:60px 10%;
      background:
      linear-gradient(135deg,#E8F7F5,#FFFFFF,#F4F1FF);
    }

    .hero h1{
      font-size:4rem;
      margin-bottom:20px;
      color:#0E4C68;
    }

    .hero p{
      max-width:800px;
      margin:auto;
      font-size:1.25rem;
      color:#455;
    }

    .buttons{
      margin-top:40px;
    }

    .btn{
      display:inline-block;
      padding:16px 34px;
      border-radius:40px;
      text-decoration:none;
      margin:10px;
      font-weight:bold;
      transition:.3s;
    }

    .primary{
      background:#0E7C86;
      color:white;
    }

    .primary:hover{
      background:#0A5F67;
    }

    .secondary{
      border:2px solid #0E7C86;
      color:#0E7C86;
    }

    .secondary:hover{
      background:#0E7C86;
      color:white;
    }

    section{
      padding:90px 10%;
    }

    h2{
      font-size:2.5rem;
      margin-bottom:20px;
      color:#0E4C68;
    }

    .mission{
      max-width:900px;
      margin:auto;
      text-align:center;
    }

  </style>

</head>

<body>

<header>

<div class="logo">
🦋 Digestive Harmony
</div>

<nav>
{
navigation.map(item=>(
<a href={item.href}>{item.name}</a>
))
}
</nav>

</header>

<section class="hero">

<div>

<h1>Advancing Hope for IBD</h1>

<p>

Supporting individuals and families affected by
Crohn's Disease and Ulcerative Colitis through
education, advocacy, community and research.

</p>

<div class="buttons">

<a class="btn primary" href="#about">
Learn More
</a>

<a class="btn secondary" href="#involved">
Get Involved
</a>

</div>

</div>

</section>

<section id="about">

<div class="mission">

<h2>Our Mission</h2>

<p>

Digestive Harmony is dedicated to empowering
patients, caregivers and families through trusted
education, meaningful community support,
patient advocacy and research collaboration.

</p>

</div>

</section>
```astro
<section id="ibd" class="services">

  <div class="section-title">
    <h2>What We Do</h2>
    <p>
      Digestive Harmony is committed to improving lives through education,
      advocacy, community engagement, and research support.
    </p>
  </div>

  <div class="cards">

    <div class="card">
      <div class="icon">❤️</div>
      <h3>Patient Support</h3>
      <p>
        Providing encouragement, guidance, and trusted information for
        individuals and families living with IBD.
      </p>
    </div>

    <div class="card">
      <div class="icon">📚</div>
      <h3>Education</h3>
      <p>
        Easy-to-understand resources about Crohn's Disease,
        Ulcerative Colitis, treatments, nutrition, and living well.
      </p>
    </div>

    <div class="card">
      <div class="icon">🔬</div>
      <h3>Research</h3>
      <p>
        Supporting awareness of scientific discoveries and future
        research initiatives that improve patient outcomes.
      </p>
    </div>

    <div class="card">
      <div class="icon">🤝</div>
      <h3>Community</h3>
      <p>
        Bringing together patients, caregivers, volunteers,
        healthcare professionals, and advocates.
      </p>
    </div>

  </div>

</section>

<style>

.services{
    background:white;
    padding:90px 10%;
}

.section-title{
    text-align:center;
    max-width:850px;
    margin:auto;
    margin-bottom:60px;
}

.section-title h2{
    font-size:2.6rem;
    color:#0E4C68;
    margin-bottom:18px;
}

.section-title p{
    color:#666;
    font-size:1.1rem;
}

.cards{

    display:grid;

    grid-template-columns:repeat(auto-fit,minmax(260px,1fr));

    gap:30px;

}

.card{

    background:#fff;

    border-radius:18px;

    padding:35px;

    box-shadow:0 15px 40px rgba(0,0,0,.08);

    transition:.3s;

}

.card:hover{

    transform:translateY(-8px);

}

.icon{

    font-size:2.8rem;

    margin-bottom:20px;

}

.card h3{

    margin-bottom:15px;

    color:#0E4C68;

}

.card p{

    color:#555;

}

</style>
```

</body>

</html>
